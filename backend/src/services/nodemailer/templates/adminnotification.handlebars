<html>
  <head>
    <style>
      body {
        font-family: Arial, sans-serif;
        line-height: 1.6;
        color: #333;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
      }
      .header {
        background: #0a1628;
        color: #fff;
        padding: 20px;
        text-align: center;
        border-radius: 8px 8px 0 0;
      }
      .header h1 {
        margin: 0;
        color: #ffd700;
        font-size: 20px;
      }
      .body {
        background: #f9f9f9;
        padding: 30px;
        border-radius: 0 0 8px 8px;
      }
      .alert {
        color: #38bdf8;
        font-weight: bold;
        font-size: 18px;
      }
      .detail-row {
        padding: 8px 0;
        border-bottom: 1px solid #eee;
      }
      .detail-label {
        color: #666;
        font-size: 13px;
      }
      .detail-value {
        font-weight: bold;
        color: #333;
      }
      .player-list {
        margin: 10px 0;
        padding: 0;
      }
      .player-list li {
        padding: 4px 0;
        list-style: none;
      }
      .player-name {
        font-weight: bold;
      }
      .player-pos {
        color: #666;
        font-size: 13px;
      }
      .btn {
        display: inline-block;
        background: #ffd700;
        color: #0a1628;
        padding: 12px 24px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
        margin-top: 16px;
      }
      .footer {
        text-align: center;
        margin-top: 20px;
        font-size: 12px;
        color: #999;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>New Registration Alert</h1>
      </div>
      <div class="body">
        <p class="alert">New Team Registered!</p>
        <p>A new team has registered for the Basketball Competition and is
          awaiting payment verification.</p>

        <div class="detail-row">
          <div class="detail-label">Team Name</div>
          <div class="detail-value">{{teamName}}</div>
        </div>

        <div class="detail-row">
          <div class="detail-label">Email</div>
          <div class="detail-value">{{email}}</div>
        </div>

        <div class="detail-row">
          <div class="detail-label">Phone Number</div>
          <div class="detail-value">{{phoneNumber}}</div>
        </div>

        <div class="detail-row">
          <div class="detail-label">Players ({{playerCount}})</div>
          <ul class="player-list">
            {{#each players}}
              <li>
                <span class="player-name">{{this.fullName}}</span>
                &mdash;
                <span class="player-pos">{{this.position}}</span>
                {{#if this.phoneNumber}}<br /><span class="player-pos">Phone:
                    {{this.phoneNumber}}</span>{{/if}}
              </li>
            {{/each}}
          </ul>
        </div>

        <div class="detail-row">
          <div class="detail-label">3-Point Contest</div>
          <div class="detail-value">{{threePointContest}}</div>
        </div>

        <div class="detail-row">
          <div class="detail-label">Free Throw Contest</div>
          <div class="detail-value">{{freeThrowContest}}</div>
        </div>

        <p>Please log in to the admin dashboard to review and confirm the
          payment.</p>

        <a href="{{adminUrl}}" class="btn">Go to Dashboard</a>
      </div>
      <div class="footer">
        <p>&copy; 2026 Basketball Competition. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>