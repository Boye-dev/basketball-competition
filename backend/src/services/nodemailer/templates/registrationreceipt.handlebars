<html>
  <head>
    <style>
      body {
        font-family: Arial, sans-serif;
        line-height: 1.6;
        color: #333;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
      }
      .header {
        background: #0a1628;
        color: #fff;
        padding: 20px;
        text-align: center;
        border-radius: 8px 8px 0 0;
      }
      .header h1 {
        margin: 0;
        color: #ffd700;
      }
      .body {
        background: #f9f9f9;
        padding: 30px;
        border-radius: 0 0 8px 8px;
      }
      .info {
        color: #38bdf8;
        font-weight: bold;
        font-size: 18px;
      }
      .detail-row {
        padding: 8px 0;
        border-bottom: 1px solid #eee;
      }
      .detail-label {
        color: #666;
        font-size: 13px;
      }
      .detail-value {
        font-weight: bold;
        color: #333;
      }
      .player-list {
        margin: 10px 0;
        padding: 0;
      }
      .player-list li {
        padding: 4px 0;
        list-style: none;
      }
      .player-name {
        font-weight: bold;
      }
      .player-pos {
        color: #666;
        font-size: 13px;
      }
      .contest-box {
        display: inline-block;
        background: #fff;
        border: 1px solid #eee;
        border-radius: 6px;
        padding: 10px 16px;
        margin: 4px;
      }
      .contest-label {
        font-size: 12px;
        color: #666;
      }
      .contest-name {
        font-weight: bold;
      }
      .status-badge {
        display: inline-block;
        background: #fff3cd;
        color: #856404;
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 13px;
        font-weight: bold;
      }
      .footer {
        text-align: center;
        margin-top: 20px;
        font-size: 12px;
        color: #999;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>Basketball Competition</h1>
      </div>
      <div class="body">
        <p class="info">Registration Received!</p>
        <p>Dear <strong>{{teamName}}</strong>,</p>
        <p>Thank you for registering for the Basketball Competition. Here are
          the details of your registration:</p>

        <div class="detail-row">
          <div class="detail-label">Team Name</div>
          <div class="detail-value">{{teamName}}</div>
        </div>

        <div class="detail-row">
          <div class="detail-label">Email</div>
          <div class="detail-value">{{email}}</div>
        </div>

        <div class="detail-row">
          <div class="detail-label">Phone Number</div>
          <div class="detail-value">{{phoneNumber}}</div>
        </div>

        <div class="detail-row">
          <div class="detail-label">Players</div>
          <ul class="player-list">
            {{#each players}}
              <li>
                <span class="player-name">{{this.fullName}}</span>
                &mdash;
                <span class="player-pos">{{this.position}}</span>
                {{#if this.phoneNumber}}<br /><span class="player-pos">Phone:
                    {{this.phoneNumber}}</span>{{/if}}
              </li>
            {{/each}}
          </ul>
        </div>

        <div class="detail-row">
          <div class="detail-label">Contest Representatives</div>
          <div style="margin-top: 6px;">
            <div class="contest-box">
              <div class="contest-label">3-Point Contest</div>
              <div class="contest-name">{{threePointContest}}</div>
            </div>
            <div class="contest-box">
              <div class="contest-label">Free Throw Contest</div>
              <div class="contest-name">{{freeThrowContest}}</div>
            </div>
          </div>
        </div>

        <div class="detail-row">
          <div class="detail-label">Payment Status</div>
          <div style="margin-top: 4px;"><span class="status-badge">Pending
              Verification</span></div>
        </div>

        <p style="margin-top: 20px;">Your payment proof has been received and is
          currently being reviewed. You will receive another email once your
          payment has been verified.</p>

        <p>Best regards,<br />Basketball Competition Organizers</p>
      </div>
      <div class="footer">
        <p>&copy; 2026 Basketball Competition. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>